# ─────────────────────────────────────────────
# Manivtha AI Narrative Generator — Environment
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── Server ───────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Turso (libSQL) Database ──────────────────
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ── JWT Authentication ───────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret

# ── SuperAdmin Bootstrap ─────────────────────
# Run: node scripts/seed-superadmin.js  (once after first deployment)
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=SuperSecurePassword123!

# ── Google Gemini AI ─────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Admin Emails allow-list (legacy) ──
# Comma-separated emails that get 'Admin' role on first login
ADMIN_EMAILS=
